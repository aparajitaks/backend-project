# ── Environment ─────────────────────────────────────────────────────────────
# Set to 'production' to enable JSON logging, or 'development' for pretty logging
NODE_ENV=development

# ── API Server ──────────────────────────────────────────────────────────────
# The port the Express API will listen on
PORT=3000

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Prisma database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pipeline?schema=public"

# ── Queue (Redis + BullMQ) ──────────────────────────────────────────────────
# Redis connection URL. If unavailable, the app falls back to an in-memory queue.
REDIS_URL="redis://localhost:6379"

# ── File Storage ────────────────────────────────────────────────────────────
# Relative or absolute path where Multer will store uploaded image files
UPLOAD_DIR="./uploads"

# Maximum upload size in megabytes (enforced by Multer and Zod)
MAX_FILE_SIZE_MB=10

# ── Analysis Configuration ──────────────────────────────────────────────────
# Minimum allowed dimension (width or height) in pixels
MIN_IMAGE_DIMENSION=400

# Laplacian variance threshold below which an image is considered blurry
BLUR_THRESHOLD=80

# Maximum time (in milliseconds) to wait for Tesseract OCR before failing the check
OCR_TIMEOUT_MS=10000
