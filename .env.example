# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/media_pipeline

# Test Database (only needed for running tests)
TEST_DATABASE_URL=postgresql://user:pass@localhost:5433/pipeline_test

# Redis
REDIS_URL=redis://localhost:6379

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Image Analysis Thresholds
BLUR_THRESHOLD=80
MIN_IMAGE_DIMENSION=300
OCR_TIMEOUT_MS=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
