{
  "name": "image-processing-pipeline",
  "version": "1.0.0",
  "description": "Production-quality image upload and processing pipeline API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest src/tests/unit",
    "test:integration": "jest src/tests/integration",
    "test:e2e": "jest --runInBand src/tests/e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.76.9",
    "dotenv": "^16.4.7",
    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "http-errors": "^2.0.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/dotenv": "^8.2.3",
    "@types/http-errors": "^2.0.4",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.17.10",
    "@types/sharp": "^0.31.1",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
