{
  "name": "image-processing-pipeline",
  "version": "1.0.0",
  "description": "Production-quality image upload and processing pipeline API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "worker:dev": "ts-node-dev --respawn --transpile-only --exit-child src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "seed": "ts-node prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.76.9",
    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "http-errors": "^2.0.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/http-errors": "^2.0.4",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.17.10",
    "@types/sharp": "^0.31.1",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
